# CinePrompt MCP local configuration

# Default provider used by search tools when the request does not specify one.
# Supported values: mock, tmdb, omdb
CINEPROMPT_PROVIDER=mock

# Required only when using the TMDb provider.
TMDB_API_KEY=

# Optional override for tests or local development.
TMDB_BASE_URL=https://api.themoviedb.org/3

# Required only when using the OMDb provider.
OMDB_API_KEY=

# Optional override for tests or local development.
OMDB_BASE_URL=http://www.omdbapi.com/
